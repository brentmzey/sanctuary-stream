# Sanctuary Stream - Environment Variables Template
# Copy this file to .env and fill in your actual values

# PocketBase Configuration — local dev points to 127.0.0.1, production points to PocketHost
PB_URL=https://your-app.pockethost.io

# PocketHost Production FTP + Admin credentials
# Used by scripts/migrate-to-pockethost.sh for uploading migrations & hooks
POCKETHOST_URL=https://your-app.pockethost.io
PB_ADMIN_EMAIL=brentmzey4795@gmail.com
PB_ADMIN_PASS=your-admin-password

# Webhook — fires when a sermon is published (optional; leave empty to disable)
# Any HTTP endpoint that can receive a POST with JSON body
WEBHOOK_SERMON_URL=

# Bridge Service Account (for Church PC)
BRIDGE_EMAIL=bridge@sanctuary.local
BRIDGE_PASS=your-secure-password

# OBS WebSocket Configuration
OBS_URL=ws://127.0.0.1:4455
OBS_PASS=your-obs-websocket-password

# Stream Configuration
STREAM_ID=default_stream_record_id

# Logging
LOG_LEVEL=info
NODE_ENV=development

# AWS Configuration (Optional - for video archival)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET=sanctuary-archives
# CLOUDFRONT_DOMAIN=your-distribution.cloudfront.net
# CLOUDFRONT_KEY_PAIR_ID=your-keypair-id
# CLOUDFRONT_PRIVATE_KEY_PATH=./private-key.pem
