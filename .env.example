# Sanctuary Stream - Environment Variables Template
# Copy this file to .env and fill in your actual values

# PocketBase Configuration
PB_URL=https://your-app.pockethost.io

# Bridge Service Account (for Church PC)
BRIDGE_EMAIL=bridge@sanctuary.local
BRIDGE_PASS=your-secure-password

# OBS WebSocket Configuration
OBS_URL=ws://127.0.0.1:4455
OBS_PASS=your-obs-websocket-password

# Stream Configuration
STREAM_ID=default_stream_record_id

# Logging
LOG_LEVEL=info
NODE_ENV=development

# AWS Configuration (Optional - for video archival)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET=sanctuary-archives
# CLOUDFRONT_DOMAIN=your-distribution.cloudfront.net
# CLOUDFRONT_KEY_PAIR_ID=your-keypair-id
# CLOUDFRONT_PRIVATE_KEY_PATH=./private-key.pem
