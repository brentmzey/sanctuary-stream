## 🔄 Idempotency Strategy

### Database Level (PocketBase)

```javascript
// commands collection has UNIQUE constraint on correlation_id
// Duplicate inserts will fail with 400 error - this is EXPECTED behavior

// Frontend: Handle gracefully
try {
  await pb.collection('commands').create({
    action: 'START',
    correlation_id: crypto.randomUUID(),
    executed: false,
    created_by: pb.authStore.model.id
  });
  toast.success('Stream starting...');
} catch (error) {
  if (error.status === 400 && error.data?.data?.correlation_id) {
    toast.info('Request already in progress');
  } else {
    toast.error('Failed to start stream');
    console.error(error);
  }
}
```

### Bridge Service Level

```typescript
// sanctuary-bridge/src/services/command-processor.ts
import PocketBase from 'pocketbase';
import { logger } from '../utils/logger';

export class CommandProcessor {
  private processedIds = new Set<string>();

  async processCommand(command: Command) {
    // Double-check idempotency (defense in depth)
    if (this.processedIds.has(command.correlation_id)) {
      logger.warn('Command already processed', { correlation_id: command.correlation_id });
      return;
    }

    // Check database state
    if (command.executed) {
      logger.info('Command already executed', { id: command.id });
      return;
    }

    try {
      // Execute OBS action
      if (command.action === 'START') {
        await this.obs.call('StartStream');
      } else if (command.action === 'STOP') {
        await this.obs.call('StopStream');
      }

      // Mark as executed in database (atomic update)
      await this.pb.collection('commands').update(command.id, {
        executed: true
      });

      // Track in memory (for session)
      this.processedIds.add(command.correlation_id);

      logger.info('Command executed successfully', { 
        id: command.id, 
        action: command.action 
      });
    } catch (error) {
      logger.error('Command execution failed', { 
        id: command.id, 
        error: error.message 
      });
      throw error;
    }
  }
}
```

### Testing Idempotency

```typescript
// sanctuary-bridge/tests/idempotency.test.ts
import { describe, it, expect, vi } from 'vitest';
import { CommandProcessor } from '../src/services/command-processor';
import { createMockOBS, createMockPocketBase } from './mocks';

describe('Command Idempotency', () => {
  it('should only execute command once even if received twice', async () => {
    const mockOBS = createMockOBS();
    const mockPB = createMockPocketBase();
    const processor = new CommandProcessor(mockOBS, mockPB);

    const command = {
      id: 'cmd1',
      action: 'START',
      correlation_id: 'unique-uuid-123',
      executed: false
    };

    // Process same command twice
    await processor.processCommand(command);
    await processor.processCommand({ ...command, executed: true });

    // OBS should only be called once
    expect(mockOBS.call).toHaveBeenCalledTimes(1);
    expect(mockOBS.call).toHaveBeenCalledWith('StartStream');
  });

  it('should handle database unique constraint violation', async () => {
    const mockPB = createMockPocketBase();
    
    // First create succeeds
    await mockPB.collection('commands').create({
      action: 'START',
      correlation_id: 'uuid-123'
    });

    // Second create with same correlation_id fails
    await expect(
      mockPB.collection('commands').create({
        action: 'START',
        correlation_id: 'uuid-123' // Duplicate!
      })
    ).rejects.toThrow('correlation_id must be unique');
  });
});
```

