# 🛠️ Development Guide - Sanctuary Stream

## Overview

This guide covers local development, testing, schema management, and environment consistency.

---

## 🏗️ Initial Setup

### 1. Prerequisites

```bash
# Check versions
node --version   # Should be 18+
npm --version    # Should be 9+
rust --version   # Should be 1.70+ (for Tauri)

# Install PocketBase CLI (for local development)
# macOS
brew install pocketbase

# Linux
wget https://github.com/pocketbase/pocketbase/releases/download/v0.22.0/pocketbase_0.22.0_linux_amd64.zip
unzip pocketbase_0.22.0_linux_amd64.zip
sudo mv pocketbase /usr/local/bin/

# Windows (using Scoop)
scoop install pocketbase
```

### 2. Clone and Install

```bash
# Clone repository
git clone https://github.com/your-org/sanctuary-stream.git
cd sanctuary-stream

# Install root dependencies
npm install

# Install workspace dependencies
npm install --workspaces
```

### 3. Environment Configuration

```bash
# Create environment files for each component
cp .env.example .env
cp sanctuary-app/.env.example sanctuary-app/.env
cp sanctuary-bridge/.env.example sanctuary-bridge/.env
```

---

## 🗄️ PocketBase Schema Management

### Local Development Schema

#### Step 1: Run Local PocketBase

```bash
# Create local PocketBase directory
mkdir -p pocketbase/local
cd pocketbase/local

# Start PocketBase (creates pb_data/ directory)
pocketbase serve --http=127.0.0.1:8090

# Access Admin UI: http://127.0.0.1:8090/_/
# Create admin account on first run
```

#### Step 2: Create Schema Script

Create `pocketbase/schema-init.js`:

```javascript
#!/usr/bin/env node
/**
 * PocketBase Schema Initialization
 * Ensures consistent schema across local/staging/production
 * Run with: node pocketbase/schema-init.js <environment>
 */

const PocketBase = require('pocketbase/cjs');
const fs = require('fs');
const path = require('path');

const ENVIRONMENTS = {
  local: { url: 'http://127.0.0.1:8090', admin: 'admin@local.dev' },
  staging: { url: 'https://staging.pockethost.io', admin: 'admin@sanctuary.dev' },
  production: { url: 'https://production.pockethost.io', admin: 'admin@sanctuary.church' }
};

async function initSchema(env = 'local') {
  const config = ENVIRONMENTS[env];
  if (!config) {
    console.error(`Invalid environment: ${env}`);
    process.exit(1);
  }

  const pb = new PocketBase(config.url);
  
  // Authenticate as admin
  const password = process.env[`PB_ADMIN_PASSWORD_${env.toUpperCase()}`];
  if (!password) {
    console.error(`Missing PB_ADMIN_PASSWORD_${env.toUpperCase()} environment variable`);
    process.exit(1);
  }

  await pb.admins.authWithPassword(config.admin, password);

  console.log(`✅ Connected to ${env} PocketBase at ${config.url}`);

  // Create/Update Collections
  await ensureUsersCollection(pb);
  await ensureCommandsCollection(pb);
  await ensureStreamsCollection(pb);
  await createTestUsers(pb, env);
  await createDefaultStreamRecord(pb);

  console.log(`✅ Schema initialization complete for ${env}`);
}

async function ensureUsersCollection(pb) {
  try {
    await pb.collections.getOne('users');
    console.log('✓ Users collection exists');
  } catch (e) {
    console.log('Creating users collection...');
    // Users collection is auto-created by PocketBase
    // Just need to add custom 'role' field
    const collection = await pb.collections.getOne('users');
    await pb.collections.update(collection.id, {
      schema: [
        ...collection.schema,
        {
          name: 'role',
          type: 'select',
          required: true,
          options: {
            maxSelect: 1,
            values: ['admin', 'pastor', 'tech']
          }
        }
      ]
    });
    console.log('✅ Users collection configured');
  }
}

async function ensureCommandsCollection(pb) {
  const schema = [
    {
      name: 'action',
      type: 'select',
      required: true,
      options: {
        maxSelect: 1,
        values: ['START', 'STOP']
      }
    },
    {
      name: 'executed',
      type: 'bool',
      required: true
    },
    {
      name: 'correlation_id',
      type: 'text',
      required: true,
      options: {
        min: 36,
        max: 36,
        pattern: '^[a-f0-9]{8}-[a-f0-9]{4}-4[a-f0-9]{3}-[89ab][a-f0-9]{3}-[a-f0-9]{12}$'
      }
    },
    {
      name: 'payload',
      type: 'json',
      required: false
    },
    {
      name: 'created_by',
      type: 'relation',
      required: true,
      options: {
        collectionId: 'users',
        cascadeDelete: false,
        maxSelect: 1
      }
    }
  ];

  const indexes = [
    'CREATE UNIQUE INDEX idx_correlation_id ON commands (correlation_id)',
    'CREATE INDEX idx_executed ON commands (executed)',
    'CREATE INDEX idx_created ON commands (created)'
  ];

  const listRule = '@request.auth.id != ""';
  const createRule = '@request.auth.role = "admin" || @request.auth.role = "pastor"';
  const updateRule = '@request.auth.role = "tech"';

  try {
    const collection = await pb.collections.getOne('commands');
    await pb.collections.update(collection.id, {
      schema,
      indexes,
      listRule,
      createRule,
      updateRule,
      deleteRule: null
    });
    console.log('✓ Commands collection updated');
  } catch (e) {
    console.log('Creating commands collection...');
    await pb.collections.create({
      name: 'commands',
      type: 'base',
      schema,
      indexes,
      listRule,
      createRule,
      updateRule,
      deleteRule: null
    });
    console.log('✅ Commands collection created');
  }
}

async function ensureStreamsCollection(pb) {
  const schema = [
    {
      name: 'status',
      type: 'select',
      required: true,
      options: {
        maxSelect: 1,
        values: ['live', 'idle']
      }
    },
    {
      name: 'heartbeat',
      type: 'date',
      required: true
    },
    {
      name: 'youtube_url',
      type: 'url',
      required: false
    },
    {
      name: 'metadata',
      type: 'json',
      required: false
    }
  ];

  const indexes = [
    'CREATE INDEX idx_status ON streams (status)'
  ];

  const listRule = '@request.auth.id != ""';
  const updateRule = '@request.auth.role = "tech"';

  try {
    const collection = await pb.collections.getOne('streams');
    await pb.collections.update(collection.id, {
      schema,
      indexes,
      listRule,
      createRule: null,
      updateRule,
      deleteRule: null
    });
    console.log('✓ Streams collection updated');
  } catch (e) {
    console.log('Creating streams collection...');
    await pb.collections.create({
      name: 'streams',
      type: 'base',
      schema,
      indexes,
      listRule,
      createRule: null,
      updateRule,
      deleteRule: null
    });
    console.log('✅ Streams collection created');
  }
}

async function createTestUsers(pb, env) {
  if (env !== 'local') {
    console.log('⚠ Skipping test user creation (not local environment)');
    return;
  }

  const testUsers = [
    { email: 'admin@local.dev', password: 'admin123456', role: 'admin', name: 'Admin User' },
    { email: 'pastor@local.dev', password: 'pastor123456', role: 'pastor', name: 'Pastor John' },
    { email: 'bridge@local.dev', password: 'bridge123456', role: 'tech', name: 'Bridge Service' }
  ];

  for (const user of testUsers) {
    try {
      await pb.collection('users').create(user);
      console.log(`✅ Created test user: ${user.email}`);
    } catch (e) {
      if (e.status === 400 && e.data?.data?.email) {
        console.log(`✓ Test user exists: ${user.email}`);
      } else {
        console.error(`❌ Failed to create ${user.email}:`, e.message);
      }
    }
  }
}

async function createDefaultStreamRecord(pb) {
  try {
    const existing = await pb.collection('streams').getFullList();
    if (existing.length > 0) {
      console.log('✓ Default stream record exists');
      return;
    }

    const record = await pb.collection('streams').create({
      status: 'idle',
      heartbeat: new Date().toISOString(),
      metadata: {}
    });
    
    console.log(`✅ Created default stream record: ${record.id}`);
    console.log(`   Add this to your .env files: STREAM_ID=${record.id}`);
  } catch (e) {
    console.error('❌ Failed to create stream record:', e.message);
  }
}

// Run
const env = process.argv[2] || 'local';
initSchema(env).catch(console.error);
```

#### Step 3: Initialize Schema

```bash
# Add to package.json scripts
npm pkg set scripts.schema:init:local="node pocketbase/schema-init.js local"
npm pkg set scripts.schema:init:staging="node pocketbase/schema-init.js staging"
npm pkg set scripts.schema:init:production="node pocketbase/schema-init.js production"

# Set admin password for local
export PB_SANCTUARY_STREAM_PASSWORD_LOCAL=your-admin-password

# Run schema initialization
npm run schema:init:local
```

### Schema Export/Import

```bash
# Export schema from local PocketBase
cd pocketbase/local
pocketbase admin backup

# This creates pb_data/backups/*.zip
# Extract schema only:
unzip -p pb_data/backups/latest.zip pb_schema.json > ../schema.json

# Import to another environment
# Via PocketBase Admin UI: Settings → Import collections → Upload schema.json
```

