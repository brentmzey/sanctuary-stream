## 🔧 Schema Migration Workflow

### 1. Make Schema Changes Locally

```bash
# Start local PocketBase
cd pocketbase/local
pocketbase serve

# Make changes via Admin UI
# http://127.0.0.1:8090/_/

# Export updated schema
pocketbase admin backup
unzip -p pb_data/backups/latest.zip pb_schema.json > ../schema-v2.json
```

### 2. Create Migration Script

```javascript
// pocketbase/migrations/001_add_recording_url.js
module.exports = {
  up: async (pb) => {
    const collection = await pb.collections.getOne('streams');
    await pb.collections.update(collection.id, {
      schema: [
        ...collection.schema,
        {
          name: 'recording_url',
          type: 'url',
          required: false
        }
      ]
    });
    console.log('✅ Added recording_url field to streams');
  },

  down: async (pb) => {
    const collection = await pb.collections.getOne('streams');
    const schema = collection.schema.filter(f => f.name !== 'recording_url');
    await pb.collections.update(collection.id, { schema });
    console.log('✅ Removed recording_url field from streams');
  }
};
```

### 3. Run Migrations

```bash
# pocketbase/migrate.js
const PocketBase = require('pocketbase/cjs');
const fs = require('fs');
const path = require('path');

async function runMigrations(env) {
  const config = require('./environments')[env];
  const pb = new PocketBase(config.url);
  
  await pb.admins.authWithPassword(config.admin, process.env.PB_ADMIN_PASSWORD);

  const migrations = fs.readdirSync('./migrations')
    .filter(f => f.endsWith('.js'))
    .sort();

  for (const file of migrations) {
    console.log(`Running migration: ${file}`);
    const migration = require(`./migrations/${file}`);
    await migration.up(pb);
  }

  console.log('✅ All migrations complete');
}

const env = process.argv[2] || 'local';
runMigrations(env).catch(console.error);
```

```bash
# Run migrations
export PB_ADMIN_PASSWORD=your-password
node pocketbase/migrate.js staging
node pocketbase/migrate.js production
```

