{
  "name": "sanctuary-stream",
  "version": "0.2.1",
  "description": "Secure-by-Design church streaming control system with real-time remote management",
  "author": "Sanctuary Stream Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brentmzey/sanctuary-stream.git"
  },
  "workspaces": [
    "sanctuary-app",
    "sanctuary-bridge",
    "sanctuary-cli"
  ],
  "scripts": {
    "sanctuary": "tsx sanctuary-cli/src/index.ts",
    "dev": "concurrently \"npm run dev:pocketbase\" \"npm run dev:bridge\" \"npm run dev:app\"",
    "dev:all": "concurrently -n \"obs,bridge,app\" -c \"yellow,cyan,green\" \"npm run mock:obs\" \"npm run dev:bridge\" \"npm run dev:app\"",
    "dev:full": "concurrently -n \"pb,obs,bridge,app\" -c \"blue,yellow,cyan,green\" \"npm run dev:pocketbase\" \"npm run mock:obs\" \"npm run dev:bridge\" \"npm run dev:app\"",
    "dev:app": "npm run dev --workspace=sanctuary-app",
    "dev:bridge": "npm run dev --workspace=sanctuary-bridge",
    "dev:pocketbase": "cd pocketbase/local && ./pocketbase serve --http=127.0.0.1:8090",
    "build": "npm run build:app && npm run build:bridge",
    "build:app": "cd sanctuary-app && npm run build",
    "build:bridge": "cd sanctuary-bridge && npm run build",
    "test": "npm run test:app && npm run test:bridge",
    "test:app": "cd sanctuary-app && npm test",
    "test:bridge": "cd sanctuary-bridge && npm test",
    "test:e2e": "playwright test -c integration-tests/playwright.config.ts",
    "test:coverage": "cd sanctuary-app && npm run test:coverage && cd ../sanctuary-bridge && npm run test:coverage",
    "lint": "eslint . --ext .ts,.tsx --ignore-path .eslintignore",
    "lint:app": "cd sanctuary-app && npm run lint",
    "lint:bridge": "cd sanctuary-bridge && npm run lint",
    "typecheck": "npm run typecheck:app && npm run typecheck:bridge",
    "typecheck:app": "cd sanctuary-app && npm run typecheck",
    "typecheck:bridge": "cd sanctuary-bridge && npm run typecheck",
    "validate": "./scripts/validate.sh",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "prepare": "husky install",
    "setup": "./scripts/setup.sh",
    "release": "./scripts/release.sh",
    "schema:init:local": "tsx pocketbase/schema-init.ts local",
    "mock:obs": "tsx scripts/mock-obs.ts",
    "clean": "rm -rf sanctuary-app/dist sanctuary-bridge/dist pocketbase/local/pb_data",
    "clean:all": "npm run clean && rm -rf node_modules sanctuary-app/node_modules sanctuary-bridge/node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "happy-dom": "^17.1.0",
    "husky": "^8.0.3",
    "lint-staged": "^16.2.7",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.1.0",
    "ws": "^8.19.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "pocketbase": "^0.26.8",
    "vite": "7.3.1"
  }
}
