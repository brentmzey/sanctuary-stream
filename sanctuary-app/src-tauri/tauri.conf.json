{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Sanctuary Stream",
    "version": "0.4.4"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": true
      },
      "fs": {
        "all": false,
        "readDir": true,
        "readFile": true,
        "scope": [
          "$APPDATA/*"
        ],
        "writeFile": true
      },
      "http": {
        "all": true,
        "scope": [
          "http://127.0.0.1:8090/*",
          "http://localhost:8090/*",
          "https://*.pockethost.io/*",
          "wss://*.pockethost.io/*",
          "ws://127.0.0.1:4455/*",
          "ws://localhost:4455/*",
          "https://**",
          "wss://**"
        ]
      },
      "notification": {
        "all": true
      },
      "shell": {
        "all": false,
        "open": true
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "maximize": true,
        "minimize": true,
        "show": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Utility",
      "copyright": "Copyright © 2026 Sanctuary Stream Contributors",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.sanctuary.stream",
      "longDescription": "Secure-by-Design church streaming control system",
      "macOS": {
        "minimumSystemVersion": "10.13"
      },
      "shortDescription": "Church streaming control",
      "targets": [
        "app",
        "dmg",
        "msi",
        "deb",
        "appimage"
      ],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256"
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://*:* https://*:* ws://*:* wss://*:*; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; media-src 'self' https: data: blob:"
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "Sanctuary Stream",
        "width": 1200
      }
    ]
  }
}
