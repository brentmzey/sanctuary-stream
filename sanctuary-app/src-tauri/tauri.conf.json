{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Sanctuary Stream",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": true
      },
      "fs": {
        "all": false,
        "readFile": true,
        "writeFile": true,
        "readDir": true,
        "scope": ["$APPDATA/*"]
      },
      "http": {
        "all": true,
        "scope": [
          "http://127.0.0.1:8090/*",
          "http://localhost:8090/*",
          "https://*.pockethost.io/*"
        ]
      },
      "notification": {
        "all": true
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "maximize": true,
        "minimize": true
      }
    },
    "bundle": {
      "active": true,
      "targets": ["app", "dmg", "msi", "deb", "appimage"],
      "identifier": "com.sanctuary.stream",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "copyright": "Copyright © 2026 Sanctuary Stream Contributors",
      "category": "Utility",
      "shortDescription": "Church streaming control",
      "longDescription": "Zero-trust church streaming control system",
      "macOS": {
        "minimumSystemVersion": "10.13"
      },
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256"
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://localhost:8090 http://127.0.0.1:8090 https://*.pockethost.io wss://*.pockethost.io; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "title": "Sanctuary Stream",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
