{
  "name": "sanctuary-bridge",
  "version": "0.2.2",
  "description": "OBS WebSocket bridge service for Sanctuary Stream",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:exe": "bun build ./src/index.ts --compile --outfile dist/sanctuary-bridge",
    "build:exe:windows": "bun build ./src/index.ts --compile --target=bun-windows-x64 --outfile dist/sanctuary-bridge.exe",
    "build:exe:linux": "bun build ./src/index.ts --compile --target=bun-linux-x64 --outfile dist/sanctuary-bridge-linux",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "eventsource": "^4.1.0",
    "googleapis": "^171.4.0",
    "lint-staged": "16.2.7",
    "obs-websocket-js": "^5.0.5",
    "pocketbase": "^0.26.8",
    "vite": "7.3.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
